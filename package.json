{
  "name": "@danielarndt0/cnpj-db-loader",
  "version": "1.0.0",
  "description": "Practical CLI for preparing Brazilian Federal Revenue CNPJ open data for PostgreSQL.",
  "author": "Daniel Arndt",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cnpj-db-loader": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pg": "^8.13.1",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.20.1",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
